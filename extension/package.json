{
  "name": "resume-copilot-extension",
  "displayName": "Resume Co-Pilot",
  "version": "0.1.0",
  "description": "Scores job listings and pre-fills applications from your verified resume memory.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.89.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.279",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.7.2"
  },
  "manifest": {
    "host_permissions": [
      "https://*.greenhouse.io/*",
      "https://*.lever.co/*"
    ],
    "permissions": [
      "storage",
      "alarms"
    ]
  }
}
