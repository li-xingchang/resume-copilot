# =============================================================================
# Resume Intelligence Co-Pilot — Environment Variables
# Copy to .env (backend) and .env.local (frontend) and fill in values.
# NEVER commit real values. All secrets should be in a secrets manager in prod.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Backend (FastAPI) — copy to backend/.env
# -----------------------------------------------------------------------------

# Postgres with pgvector. Use asyncpg driver for async SQLAlchemy.
# Supabase example: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/resume_copilot

# OpenAI (embedding + chat models)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# AWS S3 for PDF storage
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=resume-copilot-pdfs

# Auth (Clerk)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# CORS — add your Vercel deployment URL in prod
CORS_ORIGINS=["http://localhost:3000"]

# App URLs
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend (Next.js) — copy to frontend/.env.local
# -----------------------------------------------------------------------------

NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (Next.js SDK)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboard

# -----------------------------------------------------------------------------
# Extension (Plasmo) — set as PLASMO_PUBLIC_* for content script access
# These are bundled into the extension at build time, so use non-secret values.
# -----------------------------------------------------------------------------

PLASMO_PUBLIC_BACKEND_URL=http://localhost:8000
PLASMO_PUBLIC_APP_URL=http://localhost:3000
